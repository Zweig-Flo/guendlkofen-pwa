  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://svg.eu.auth0.com/authorize?audience=https%3A%2F%2Fapi.guendlkofen.app",
            "tokenUrl": "https://svg.eu.auth0.com/oauth/token",
            "scopes": {
              "openid": "OpenID Connect",
              "profile": "User profile",
              "email": "Email address"
            }
          }
        }
      },
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "MessageDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Hello World!"
          }
        },
        "required": [
          "message"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Local user id",
            "example": "cmrf55tba0000wftfb78qh894"
          },
          "email": {
            "type": "string",
            "description": "Email address, if known from the Auth0 token",
            "example": "player@example.com",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Display name, if known from the Auth0 token",
            "example": "Max Mustermann",
            "nullable": true
          },
          "locale": {
            "type": "string",
            "description": "Preferred locale of the user",
            "example": "de"
          },
          "isSuperAdmin": {
            "type": "boolean",
            "description": "Whether the user is a platform super admin",
            "example": false
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "locale",
          "isSuperAdmin"
        ]
      },
      "CreateClubDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Club name",
            "example": "SV Gündlkofen"
          }
        },
        "required": [
          "name"
        ]
      },
      "ClubDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Club id",
            "example": "cmrf55tba0000wftfb78qh894"
          },
          "name": {
            "type": "string",
            "description": "Club name",
            "example": "SV Gündlkofen"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "UpdateClubDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Club name",
            "example": "SV Gündlkofen"
          }
        }
      },
      "TeamDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Team id",
            "example": "cmrf55tba0001wftfb78qh895"
          },
          "clubId": {
            "type": "string",
            "description": "Id of the club the team belongs to",
            "example": "cmrf55tba0000wftfb78qh894"
          },
          "name": {
            "type": "string",
            "description": "Team name",
            "example": "Herren 1"
          },
          "sport": {
            "type": "string",
            "description": "Sport of the team",
            "example": "Tennis"
          },
          "league": {
            "type": "string",
            "description": "League the team plays in",
            "example": "Bezirksliga",
            "nullable": true
          },
          "rank": {
            "type": "number",
            "description": "Ordering among the club's teams of the same sport; 1 is the highest team",
            "example": 1,
            "minimum": 1
          }
        },
        "required": [
          "id",
          "clubId",
          "name",
          "sport",
          "league",
          "rank"
        ]
      },
      "CreateTeamDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Team name",
            "example": "Herren 1"
          },
          "sport": {
            "type": "string",
            "description": "Sport of the team",
            "example": "Tennis"
          },
          "league": {
            "type": "string",
            "description": "League the team plays in",
            "example": "Bezirksliga"
          },
          "rank": {
            "type": "number",
            "description": "Ordering among the club's teams of the same sport; 1 is the highest team",
            "example": 1,
            "minimum": 1
          }
        },
        "required": [
          "name",
          "sport",
          "rank"
        ]
      },
      "UpdateTeamDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Team name",
            "example": "Herren 1"
          },
          "sport": {
            "type": "string",
            "description": "Sport of the team",
            "example": "Tennis"
          },
          "league": {
