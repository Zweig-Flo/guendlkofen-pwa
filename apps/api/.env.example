# Auth0 tenant, e.g. my-tenant.eu.auth0.com (no protocol, no trailing slash)
AUTH0_DOMAIN=
# API identifier configured in Auth0 (Applications > APIs)
AUTH0_AUDIENCE=
# Client ID of the Auth0 SPA application — used for the Swagger UI login flow
AUTH0_CLIENT_ID=

PORT=3000

# Postgres connection (matches compose.yaml at the repo root for local dev)
DATABASE_URL=postgresql://guendlkofen:guendlkofen@localhost:5432/guendlkofen

# Comma-separated list of emails that are promoted to super admin on login
# (once promoted, users stay super admin even if removed from this list)
SUPER_ADMIN_EMAILS=

# Resend API key for outbound email. If unset, emails are logged to the
# console (with their links) instead of being delivered — handy for local dev.
RESEND_API_KEY=
# Sender address for outbound email (only used when RESEND_API_KEY is set)
EMAIL_FROM=no-reply@guendlkofen.app
# Base URL of the managing portal; invitation links point at ${PORTAL_URL}/invite/<token>
PORTAL_URL=http://localhost:5174
