# Auth0 tenant, e.g. my-tenant.eu.auth0.com (no protocol, no trailing slash)
AUTH0_DOMAIN=
# API identifier configured in Auth0 (Applications > APIs)
AUTH0_AUDIENCE=
# Client ID of the Auth0 SPA application — used for the Swagger UI login flow
AUTH0_CLIENT_ID=

PORT=3000

# Postgres connection (matches compose.yaml at the repo root for local dev)
DATABASE_URL=postgresql://guendlkofen:guendlkofen@localhost:5432/guendlkofen

# Comma-separated list of emails that are promoted to super admin on login
# (once promoted, users stay super admin even if removed from this list)
SUPER_ADMIN_EMAILS=

# Resend API key for outbound email. If unset, emails are logged to the
# console (with their links) instead of being delivered — handy for local dev.
RESEND_API_KEY=
# Sender address for outbound email (only used when RESEND_API_KEY is set)
EMAIL_FROM=no-reply@jeriel.resend.app
# Base URL of the managing portal; invitation links point at ${PORTAL_URL}/invite/<token>
PORTAL_URL=http://localhost:5174

# Base URL of the player PWA; reminder deep links point at ${WEB_APP_URL}/clubs/...
WEB_APP_URL=http://localhost:5173

# Web Push (VAPID) keys. Generate a fresh pair with:
#   npx web-push generate-vapid-keys
# If unset, push payloads are logged to the console instead of being delivered
# (and GET /me/push/public-key returns an empty key) — handy for local dev.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services (mailto: or https:). Defaults to a mailto:
# address when unset.
VAPID_SUBJECT=mailto:no-reply@jeriel.resend.app

# Symmetric key used to encrypt team-chat messages at rest (AES-256-GCM).
# 32 bytes, hex-encoded (64 hex chars). Generate a fresh key with:
#   openssl rand -hex 32
# The API refuses to boot without a valid 32-byte key.
CHAT_ENCRYPTION_KEY=
