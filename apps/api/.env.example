# Auth0 tenant, e.g. my-tenant.eu.auth0.com (no protocol, no trailing slash)
AUTH0_DOMAIN=
# API identifier configured in Auth0 (Applications > APIs)
AUTH0_AUDIENCE=
# Client ID of the Auth0 SPA application — used for the Swagger UI login flow
AUTH0_CLIENT_ID=

PORT=3000

# Postgres connection (matches compose.yaml at the repo root for local dev)
DATABASE_URL=postgresql://guendlkofen:guendlkofen@localhost:5432/guendlkofen
