// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ClubRole {
  CLUB_ADMIN
  MEMBER
}

enum TeamRole {
  TEAM_ADMIN
  PLAYER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum EventStatus {
  SCHEDULED
  CANCELLED
}

enum EventSource {
  MANUAL
  IMPORT
}

enum HomeAway {
  HOME
  AWAY
  NEUTRAL
}

enum VoteChoice {
  YES
  NO
}

enum ReminderKind {
  VOTE_7D
  VOTE_2D
  INFO_1D
}

model User {
  id           String  @id @default(cuid())
  auth0Sub     String  @unique
  email        String?
  name         String?
  locale       String  @default("de")
  isSuperAdmin Boolean @default(false)

  clubMemberships ClubMembership[]
  teamMemberships TeamMembership[]

  votes Vote[]

  pushSubscriptions PushSubscription[]
  reminderLogs      ReminderLog[]

  sentInvitations     Invitation[] @relation("InvitedBy")
  acceptedInvitations Invitation[] @relation("AcceptedBy")

  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id   String @id @default(cuid())
  name String

  teams       Team[]
  memberships ClubMembership[]
  invitations Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id     String  @id @default(cuid())
  clubId String
  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name   String
  sport  String
  league String?
  // Ordering among the club's teams of the same sport; 1 = highest team
  rank   Int

  memberships TeamMembership[]

  events Event[]

  chatMessages ChatMessage[]

  invitationAssignments InvitationTeamAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, sport, rank])
}

model ClubMembership {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId String
  club   Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  role   ClubRole

  createdAt DateTime @default(now())

  @@unique([userId, clubId])
}

model TeamMembership {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role   TeamRole

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
}

model Invitation {
  id       String           @id @default(cuid())
  clubId   String
  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  email    String
  clubRole ClubRole         @default(MEMBER)
  token    String           @unique
  status   InvitationStatus @default(PENDING)
  expiresAt DateTime

  // SetNull (not Cascade): the invitation audit trail survives inviter deletion
  invitedById String?
  invitedBy   User?   @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  acceptedById String?
  acceptedBy   User?   @relation("AcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  teamAssignments InvitationTeamAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvitationTeamAssignment {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role         TeamRole   @default(PLAYER)

  @@unique([invitationId, teamId])
}

model Event {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  startsAt DateTime // kickoff; drives ordering, "upcoming", vote-lock, reminders
  opponent String // free text ("SV Musterhausen"); required — a game needs one
  location String? // venue / address; optional
  homeAway HomeAway @default(HOME)
  notes    String? // free-text meta (meeting time, kit colour, …)

  status EventStatus @default(SCHEDULED)
  source EventSource @default(MANUAL)

  // Dedupe key for idempotent re-import. Null for manual events. Unique per team.
  importKey String?

  votes        Vote[]
  reminderLogs ReminderLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, importKey]) // idempotent CSV re-run; nulls don't collide in Postgres
  @@index([teamId, startsAt]) // team planner list + my-upcoming aggregation
}

model Vote {
  id      String     @id @default(cuid())
  eventId String
  event   Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice  VoteChoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // updated when a player flips YES↔NO

  @@unique([eventId, userId]) // one vote per user per event; also the upsert key
  @@index([eventId]) // tally teammates' votes for one event
}

// A single team-chat message. `content` stores the AES-256-GCM ciphertext
// (packed `v1:iv:tag:data`, all base64) — never plaintext. History outlives the
// author account (SetNull, same reasoning as invitations); it dies with the team.
model ChatMessage {
  id       String  @id @default(cuid())
  teamId   String
  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content  String

  createdAt DateTime @default(now())

  @@index([teamId, createdAt]) // cursor pagination: newest-first per team
}

// A Web Push endpoint for one device. Endpoint is globally unique and
// device-bound: re-subscribing on a device that another user previously used
// MOVES the endpoint to the current user (deletes are always self-scoped).
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String  @unique
  p256dh    String
  auth      String
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Idempotency ledger: one row per (event, user, reminder kind) so a given
// reminder is sent at most once even across concurrent scheduler ticks.
model ReminderLog {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind   ReminderKind
  sentAt DateTime     @default(now())

  @@unique([eventId, userId, kind])
}
