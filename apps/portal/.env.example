# Auth0 tenant, e.g. my-tenant.eu.auth0.com (no protocol, no trailing slash)
VITE_AUTH0_DOMAIN=
# Client ID of the Auth0 "Single Page Application"
VITE_AUTH0_CLIENT_ID=
# API identifier configured in Auth0 (must match the api's AUTH0_AUDIENCE)
VITE_AUTH0_AUDIENCE=

# Base URL of the NestJS api
VITE_API_URL=http://localhost:3000

# Base URL of the player PWA (used on the invite success screen)
VITE_PLAYER_APP_URL=http://localhost:5173
